[Unit]
Description=Infra Demo Health Service
After=network.target

[Service]
User=infraadmin
Group=infraadmin

WorkingDirectory=/opt/infra-demo

EnvironmentFile=/home/aaliya/linux-infra-intern-assignment/config/infra-demo.env

ExecStart=/usr/bin/python3 /home/aaliya/linux-infra-intern-assignment/app/app.py

